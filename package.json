{
  "name": "keyrecoder",
  "version": "1.0.0",
  "description": "Stylish and lightweight input overlay for OBS and desktop use, supporting Windows and Linux.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.xerty.keyrecoder",
    "productName": "KeyRecoder",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "XertyLoin <contact@xerty.com>",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.2.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  }
}
